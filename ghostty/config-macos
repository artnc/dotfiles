adjust-cell-height = 1
adjust-cell-width = -1
bell-audio-path = /System/Library/Sounds/Glass.aiff
config-file = config-base
font-size = 12
font-thicken = true
# Make Option behave as Alt so it emits Alt-prefixed escape sequences (e.g.
# Alt+Left = `\e[1;3D`, Alt+Backspace = `\e\x7f`). Without this, Option is used
# for typing special characters and word-level keybindings don't work
macos-option-as-alt = true
