#!/usr/bin/env bash
# Shows Claude.ai usage: "CC <session%> <session_reset>h <weekly%> <weekly_reset>h".
# Reads ORG_ID and SESSION_KEY from ~/.config/claude-usage/env.
# Get SESSION_KEY from the `sessionKey` cookie at claude.ai (devtools > Application > Cookies).

set -eu

config_file="${HOME}/.config/claude-usage/env"
fallback='CC ?'

if [[ ! -r ${config_file} ]]; then
  echo "${fallback}"
  echo "${fallback}"
  exit 0
fi

# shellcheck source=/dev/null
source "${config_file}"

response="$(curl -fsS --max-time 10 --compressed \
  "https://claude.ai/api/organizations/${ORG_ID}/usage" \
  -H 'User-Agent: Mozilla/5.0 (X11; Linux x86_64; rv:150.0) Gecko/20100101 Firefox/150.0' \
  -H 'Accept: */*' \
  -H 'Referer: https://claude.ai/settings/usage' \
  -H 'anthropic-client-platform: web_claude_ai' \
  -H 'content-type: application/json' \
  -H "Cookie: sessionKey=${SESSION_KEY}" 2> /dev/null)" || {
  echo "${fallback}"
  echo "${fallback}"
  exit 0
}

parsed="$(echo "${response}" | jq -r \
  '[(.five_hour.utilization // 0 | floor), (.five_hour.resets_at // ""), (.seven_day.utilization // 0 | floor), (.seven_day.resets_at // "")] | @tsv' 2> /dev/null)" || {
  echo "${fallback}"
  echo "${fallback}"
  exit 0
}

IFS=$'\t' read -r session_pct session_reset weekly_pct weekly_reset <<< "${parsed}"

now_ts="$(date +%s)"
# Returns "X.Yh" (one decimal) if under 10h, else "Xh"
time_until() {
  local iso="$1"
  if [[ -z ${iso} ]]; then
    echo '?'
    return
  fi
  local reset_ts
  reset_ts="$(date -d "${iso}" +%s 2> /dev/null)" || {
    echo '?'
    return
  }
  local diff=$((reset_ts - now_ts))
  if ((diff < 0)); then
    diff=0
  fi
  local hrs=$((diff / 3600))
  if ((hrs < 10)); then
    echo "${hrs}.$(((diff % 3600) / 360))h"
  else
    echo "${hrs}h"
  fi
}

# Color a percentage based on proximity to 100%
color_pct() {
  local pct="$1"
  local color
  if ((pct >= 90)); then
    color='#ff4040'
  elif ((pct >= 75)); then
    color='#ff8c00'
  elif ((pct >= 50)); then
    color='#ffd700'
  elif ((pct >= 25)); then
    color='#adff2f'
  else
    color='#90ee90'
  fi
  echo "<span foreground=\"${color}\">${pct}%</span>"
}

output="CC $(color_pct "${session_pct}") $(time_until "${session_reset}") $(color_pct "${weekly_pct}") $(time_until "${weekly_reset}")"
echo "${output}"
echo "${output}"
