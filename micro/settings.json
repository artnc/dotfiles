{
  "*.py": {
    "tabsize": 4
  },
  "colorcolumn": 80,
  "colorscheme": "twilight",
  "copilot": false,
  "cursorline": true,
  "diffgutter": true,
  "fzfopen": "newtab",
  "hltaberrors": true,
  "hltrailingws": true,
  "ignorecase": false,
  "keymenu": false,
  "matchbrace": true,
  "mkparents": true,
  "pluginrepos": ["https://raw.githubusercontent.com/MuratovAS/micro-fzfinder/main/repo.json"],
  "reload": "auto",
  "scrollbar": true,
  "scrollspeed": 8,
  "smartpaste": true,
  "softwrap": true,
  "statusformatl": "$(filename)",
  "statusformatr": "$(modified)$(overwrite)($(line),$(col)) $(status.paste)| ft:$(opt:filetype)",
  "tabsize": 2,
  "tabstospaces": true,
  "wordwrap": true
}
