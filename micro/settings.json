{
  "*.js": {
    "colorcolumn": 80
  },
  "*.jsx": {
    "colorcolumn": 80
  },
  "*.py": {
    "tabsize": 4
  },
  "*.ts": {
    "colorcolumn": 80
  },
  "*.tsx": {
    "colorcolumn": 80
  },
  "colorcolumn": 100,
  "colorscheme": "twilight",
  "cursorline": false,
  "diffgutter": true,
  "hltaberrors": true,
  "hltrailingws": true,
  "ignorecase": false,
  "mkparents": true,
  "reload": "auto",
  "scrollbar": true,
  "scrollspeed": 8,
  "showchars": "ispace=▏,itab=▏",
  "softwrap": true,
  "statusformatl": "$(filename)",
  "statusformatr": "$(modified)$(overwrite)($(line),$(col)) $(status.paste)| ft:$(opt:filetype)",
  "tabsize": 2,
  "tabstospaces": true,
  "wordwrap": true
}
